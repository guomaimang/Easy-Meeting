{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Search(*)",
      "Search(pattern:*)",
      "Search(pattern:*, include:*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(brew *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -f *)",
      "Bash(chmod -R 777 *)",
      "Bash(:(){ :|:& };:)",
      "Bash(mkfs *)",
      "Bash(dd if=*)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(sudo rm -rf *)",
      "Bash(> /dev/sda*)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)"
    ]
  }
}
